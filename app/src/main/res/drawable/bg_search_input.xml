<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused: explicit accent border, like a system input field in focus. -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/dark_background" />
            <stroke android:width="2dp" android:color="@color/primary_red" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/dark_background" />
            <stroke android:width="2dp" android:color="@color/primary_red" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <!-- Default: subtle border. -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/dark_background" />
            <stroke android:width="1dp" android:color="#40FFFFFF" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</selector>
